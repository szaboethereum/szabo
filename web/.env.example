# The deployed SzaboObjects contract address. Defaults to the Sepolia v2
# deployment when unset.
NEXT_PUBLIC_SZABO_ADDRESS=0x061077B2cdc9774cD77aC098326422667aE5a650

# Chain to read from: "sepolia" or "mainnet".
NEXT_PUBLIC_CHAIN=sepolia

# Public RPC URL. Any Sepolia / mainnet endpoint works.
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# OpenSea collection slug. Fill this after creating the collection on OpenSea.
NEXT_PUBLIC_OPENSEA_SLUG=
