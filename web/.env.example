# The deployed SzaboObjects contract address. Defaults to the mainnet
# address when unset.
NEXT_PUBLIC_SZABO_ADDRESS=0x8410b70eB54a95877305d6cD727Adda65de09f50

# Chain to read from: "sepolia" or "mainnet".
NEXT_PUBLIC_CHAIN=mainnet

# Public RPC URL for the chosen chain.
NEXT_PUBLIC_RPC_URL=https://ethereum-rpc.publicnode.com

# OpenSea collection slug. Fill this after creating the collection on OpenSea.
NEXT_PUBLIC_OPENSEA_SLUG=
